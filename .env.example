# 毒舌老友环境配置
# 复制此文件为 .env 并修改配置

# Flask配置
FLASK_APP=app.py
FLASK_ENV=production
SECRET_KEY=your-secret-key-here-change-this

# API配置
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=5004
DEBUG=false

# 数据库配置（如果需要）
# DATABASE_URL=postgresql://user:password@localhost/toxic_friends
# REDIS_URL=redis://localhost:6379/0

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log

# 安全配置
CORS_ORIGINS=http://localhost:5004,http://your-domain.com
RATE_LIMIT=100/hour